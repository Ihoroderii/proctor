# Proctor backend — copy to .env and fill in

# Database (default matches docker-compose postgres)
DATABASE_URL=postgresql+asyncpg://proctor:proctor@localhost:5432/proctor

# JWT for proctor login
JWT_SECRET=change-me-in-production-use-long-random-string

# S3 / MinIO (optional, for recording storage)
# S3_ENDPOINT_URL=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=proctor-recordings
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_USE_SSL=false

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# Agent secret (for any HTTP-based agent integration)
AGENT_SECRET=set-a-shared-secret-for-the-agent

DEBUG=false
